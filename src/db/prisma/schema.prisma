// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id Int @id @default(autoincrement())
  phoneNumber String?
  email String?
  linkedId Int?                                       // the ID of another Contact linked to this one
  linkPrecedence PRECEDENCE @default("secondary")     // "primary" if it's the first Contact in the link
  createdAt DateTime @default(now())
  updatedAt DateTime
  deletedAt DateTime?
}


enum PRECEDENCE {
  primary
  secondary
}



